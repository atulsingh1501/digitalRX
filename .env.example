# If you are running locally using start-backend.bat, leave this blank or do not create a .env file!
# The app will automatically fall back to your local server at http://127.0.0.1:3001

# If deploying to VERCEL, rename this file to .env or add this variable in Vercel's settings
# to explicitly point to your live hosted Railway/Render backend URL.
VITE_BACKEND_URL=https://your-live-backend-url.up.railway.app
